#!/usr/bin/env bash

TMPL_MKFILE=scripts/tmpl.mk

# MODULE RULES
#
# This script generates the Makefile from $TMPL_MKFILE, imposing the following
# basic module rules:
#
#	1. Every directory in `/src` and its descendant directories, including
#	`/src` itself, defines a module.
#
#	2. Every C file within a module `x` can include headers from the
#	`/x/include` directory (if it exists). E.g., `/src/main.c` and
#	`/src/ast/expr.c` can both include headers from `/src/include`, but
#	`/src/ast/expr.c` can also include from `/src/ast/include`.
#
#	3. Every C file is treated as its own translation unit.
#
#	4. Every `.c` and `.h` file in the directory is a Makefile-dependency of
#	every other such file.
#	
#	5. In keeping with [0], the -I include directories are ordered
#	according to nearness to the file, so that if `x.h` is imported in
#	`/src/abc` and there is both `/src/include/x.h` and
#	`/src/abc/include/x.h` then the latter will be chosen.
#
# 	[0]: "Directories named in -I options shall be searched in the order
# 	specified".
# 	https://pubs.opengroup.org/onlinepubs/9699919799/utilities/c99.html
#
#
# UNIT TESTS
#
# Within `/src` and its descendants, any folder named `_test` is a unit test. It
# is an independent application with its own `main` function, able to include
# headers from the module it belongs to, according to the MODULE RULES above. 
#
# It goes without saying that unit tests are excluded from the object code
# generated for the main application Makefile.
#
# The script generates a Makefile for each unit test that includes all object
# files, with the exclusion of `/src/main.c` and the other tests, for obvious
# reasons. Unit test Makefiles are included in the main Makefile, so that
#
# 	$ make unit-test src/ast/stmt
#
# runs the test inside `/src/ast/stmt/_test` (if it exists), when this command
# is executed from the project root. The script also generates and distributes
# Makefiles inside `/src`, `/src/ast` and `/src/ast/stmt`, etc. so that running
#
# 	$ make unit-test
#
# in each respective directory runs its test (if it exists) and all the tests
# recursively contained in it.
#
# Success/failure of a unit test is defined by zero/nonzero exit code.

set +x

SRCDIR=src
BUILDDIR=build

DEPS_MKFILE=scripts/deps.mk

# list_includes: output a list of the appropriate include directories from the
# given path, in keeping with rule (2.) above
function list_includes() {
	path=$1
	includedir=$path/include
	if [ -d $includedir ]; then
		echo $includedir
	fi
	parent=$(dirname $path)
	if [[ $parent != "." ]]; then
		list_includes $parent
	fi
}

function replace_valgrind_params() {
	if [[ `command -v valgrind` ]]; then
		_valgrind="valgrind --fullpath-after=\`pwd\`/src/"
		_v_flags="--num-callers=30"
		_leaks="--leak-check=full"
	fi
	sed "s|@VALGRIND@|$_valgrind|;\
		s|@VALGRINDVFLAGS@|$_v_flags|;\
		s|@VALGRINDFULLLEAKS@|$_leaks|"
}

INCLUDEDIRS=$(find $SRCDIR -type d -name include ! -path "*_test*")
SRCDIRS=$(find $SRCDIR -type d ! -name include ! -path "*_test*")

# hack in Lex/Yacc files
PARSER_FILES="$SRCDIR/ast/lex.yy.c \
	$SRCDIR/ast/gram.tab.c \
	$SRCDIR/include/gram.tab.h"
touch $PARSER_FILES

exec > $DEPS_MKFILE

printf "# Generated by $(pwd)/$(basename $0) at $(date "+%s")\n\n"

# headers
printf "HEADERS ="
for dir in $INCLUDEDIRS; do
	for f in $(find $dir -maxdepth 1 -type f -name "*.h"); do
		printf " \\"			# escape previous line
		printf "\n\t$f"
	done
done
printf "\n\n"

# objects
printf "OBJECTS ="
for dir in $SRCDIRS; do
	build_dir=$(echo $dir | sed "s/^$SRCDIR/$BUILDDIR/")
	for f in $(find $dir -maxdepth 1 -type f -name "*.c"); do
		obj=$build_dir/$(basename $f | sed "s/.c$/.o/;")
		printf " \\"			# escape previous line
		printf "\n\t$obj"
	done
done
printf "\n"

# object build commands
for dir in $SRCDIRS; do
	build_dir=$(echo $dir | sed "s/^$SRCDIR/$BUILDDIR/")
	printf "\n# $dir with build dir /$build_dir\n"
	includes=$(list_includes $dir)
	for f in $(find $dir -maxdepth 1 -type f -name "*.c"); do
		obj=$build_dir/$(basename $f | sed "s/.c$/.o/;")
		printf "$obj: $build_dir parser\n"
		printf "\t@printf \"CC\\\\t\$@\\\\n\"\n"
		printf "\t@\$(CC) \$(CFLAGS) -o \$@ -c $f "

		# the order of inclusions is important: see (5.) above.
		for inc in $includes; do
			printf -- '\\\n\t\t-I %s ' $inc
		done
		printf "\n"
	done
done

# build dirs
printf "# build dirs\n"
for dir in $SRCDIRS; do
	build_dir=$(echo $dir | sed "s/^$SRCDIR/$BUILDDIR/")
	printf "$build_dir:\n"
	printf "\t@mkdir -p \$@\n"
done

exec > /dev/tty

# hack in parser files
rm $PARSER_FILES

cat $TMPL_MKFILE | replace_valgrind_params > Makefile
