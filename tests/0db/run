#!/usr/bin/env bash

set +x

XR0=$(pwd)/bin/0v
LIBX=$(pwd)/libx
AWKFILE=$(pwd)/tests/0db/split.awk
TESTDIR=$(pwd)/tests/0db

for dir in "$TESTDIR"/*/; do
	# remove trailing slash
	dir=${dir%/}
	printf "%-${length}s ..." "$dir"
	
	# @ is the configurable debug separator
	output=$($XR0 -I "$LIBX" -r@ "$dir/test.x" < "$dir/test.cfg" 2>&1)

	tempdir=$(mktemp -d)

	# split the output by the delimiter "(0db)" and write each part
	# to a file
	echo "$output" | awk -v file_prefix="$tempdir/" -f "$AWKFILE"

	if diff -r "$tempdir" "$dir/expected" >/dev/null 2>&1; then
		npass=$((npass+1))
		printf "$pass"
	else
		nfail=$((nfail+1))
		printf "$fail"
	fi

done
